{
 "name": "arkam",
 "version": "0.1.0",
 "description": "Desktop accounting app with Next.js, Electron, Tailwind, and local SQLite",
 "private": true,
 "main": "electron/main.js",
 "scripts": {
    "predev": "node scripts/clean-next-lock.mjs",
  "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "predev:web": "node scripts/clean-next-lock.mjs",
  "dev:web": "next dev",
  "dev:electron": "wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .",
  "rebuild:native": "electron-builder install-app-deps",
  "postinstall": "electron-builder install-app-deps",
  "build": "next build",
  "build:desktop": "npm run build && electron-builder --win nsis",
  "start": "next start",
  "lint": "eslint"
 },
 "dependencies": {
  "better-sqlite3": "^12.9.0",
  "drizzle-orm": "^0.45.2",
  "i18next": "^26.0.4",
  "i18next-resources-to-backend": "^1.2.1",
  "next": "16.2.3",
  "next-i18next": "^16.0.5",
  "react": "19.2.4",
  "react-dom": "19.2.4"
 },
 "devDependencies": {
  "@tailwindcss/postcss": "^4",
  "@types/node": "^20",
  "@types/react": "^19",
  "@types/react-dom": "^19",
  "concurrently": "^9.2.1",
  "cross-env": "^10.1.0",
  "drizzle-kit": "^0.31.10",
  "electron": "^41.2.0",
  "electron-builder": "^26.8.1",
  "eslint": "^9",
  "eslint-config-next": "16.2.3",
  "tailwindcss": "^4",
  "typescript": "^5",
  "wait-on": "^9.0.5"
 },
 "build": {
  "appId": "com.arkam.accounting",
  "productName": "Arkam Accounting",
  "asar": false,
  "directories": {
   "output": "release"
  },
  "files": [
   "electron/**/*",
   "out/**/*",
   "package.json"
  ],
  "win": {
   "target": [
    "nsis"
   ]
  },
  "nsis": {
   "oneClick": false,
   "allowToChangeInstallationDirectory": true
  }
 }
}
